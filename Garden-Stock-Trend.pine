//@version=5
indicator("園長八法形態提醒", overlay=true, max_labels_count=500)

//==============================================================================
// 1. 核心參數
//==============================================================================
ma3_len            = input.int(3, "3日線")
ma5_len            = input.int(5, "5日線")
ma10_len           = input.int(10, "10日線")
ma20_len           = input.int(20, "20日線")
ma60_len           = input.int(60, "60日線")
ma120_len          = input.int(120, "120日線")
vol_ma_len         = input.int(20, "成交量均量")
atr_len            = input.int(14, "ATR 長度")

left_clean_lookback = input.int(80, "左側光溜溜回看天數", group="形態偵測")
bundle_pct_limit    = input.float(0.08, "均線糾結上限", group="形態偵測", tooltip="3/5/10/20/60/120 均線最大差距占股價比率")
big_body_pct        = input.float(4.0, "大紅K最小漲幅 (%)", group="形態偵測")
black_swan_drop_pct = input.float(8.0, "黑天鵝前日跌幅 (%)", group="形態偵測")
head_start_gap_pct  = input.float(1.5, "搶頭香開盤跳空 (%)", group="形態偵測")

strong_vol_mult     = input.float(1.8, "有量倍率", group="量價濾網")
light_vol_mult      = input.float(0.9, "無量倍率", group="量價濾網")
sell_vol_mult       = input.float(1.6, "賣點爆量倍率", group="量價濾網")

stop_loss_pct       = input.float(7.0, "固定停損 (%)", group="賣點紀律")
trail_break_pct     = input.float(0.0, "跌破10日容忍 (%)", group="賣點紀律")
first_target_mult   = input.float(3.0, "沖天砲目標倍數", group="目標價")
second_spring_mult  = input.float(1.20, "第二春目標倍數", group="目標價")
shrimp_target_mult  = input.float(1.18, "小蝦米目標倍數", group="目標價")
black_swan_mult     = input.float(1.15, "黑天鵝目標倍數", group="目標價")
wukong_target_mult  = input.float(1.25, "悟空翻身目標倍數", group="目標價")
head_start_mult     = input.float(1.08, "搶頭香目標倍數", group="目標價")

show_signal_bg      = input.bool(true, "顯示形態背景", group="視覺")

//==============================================================================
// 2. 基礎資料
//==============================================================================
ma3   = ta.sma(close, ma3_len)
ma5   = ta.sma(close, ma5_len)
ma10  = ta.sma(close, ma10_len)
ma20  = ta.sma(close, ma20_len)
ma60  = ta.sma(close, ma60_len)
ma120 = ta.sma(close, ma120_len)
vol_ma = ta.sma(volume, vol_ma_len)
atr_val = ta.atr(atr_len)

body_pct = math.abs(close - open) / math.max(open, 0.01) * 100
chg_pct  = (close - close[1]) / math.max(close[1], 0.01) * 100
gap_pct  = (open - close[1]) / math.max(close[1], 0.01) * 100

is_bull = close > open
is_bear = close < open
is_big_bull = is_bull and chg_pct >= big_body_pct
is_big_bear = is_bear and math.abs(chg_pct) >= big_body_pct
is_strong_vol = volume > vol_ma * strong_vol_mult
is_light_vol = volume < vol_ma * light_vol_mult

left_high = ta.highest(high[1], left_clean_lookback)
left_low  = ta.lowest(low, left_clean_lookback)
is_left_clean = close > left_high

bundle_high = math.max(math.max(math.max(ma3, ma5), math.max(ma10, ma20)), math.max(ma60, ma120))
bundle_low  = math.min(math.min(math.min(ma3, ma5), math.min(ma10, ma20)), math.min(ma60, ma120))
bundle_pct  = (bundle_high - bundle_low) / math.max(close, 0.01)
is_bundle   = bundle_pct <= bundle_pct_limit

big_bull_3 = is_big_bull and is_big_bull[1] and is_big_bull[2]
green_3    = is_bull and is_bull[1] and is_bull[2]
vol_3      = is_strong_vol and is_strong_vol[1] and is_strong_vol[2]
above_120  = close > ma120
cross_120_recent = ta.barssince(ta.crossover(close, ma120)) <= 2

recent_high_60 = ta.highest(high[1], 60)
recent_low_60  = ta.lowest(low, 60)

//==============================================================================
// 3. 八法觀念擷取
//==============================================================================
cond_chong_tian_pao =
    green_3 and
    big_bull_3 and
    vol_3 and
    above_120 and
    cross_120_recent and
    is_left_clean

cond_second_spring =
    green_3 and
    big_bull_3 and
    vol_3 and
    above_120 and
    not is_left_clean and
    close > recent_high_60 and
    ma20 > ma60

gap_up_now = low > high[1]
gap_up_prev = low[1] > high[2]
cond_small_shrimp =
    is_bull and
    is_bull[1] and
    gap_up_now and
    gap_up_prev and
    is_light_vol and
    is_light_vol[1] and
    above_120

cond_black_swan =
    close[1] < open[1] and
    ((open[1] - close[1]) / math.max(open[1], 0.01) * 100 >= black_swan_drop_pct) and
    volume[1] > vol_ma[1] and
    close > high[1] and
    close > ma20 and
    volume > vol_ma

cond_wukong =
    is_bundle[1] and
    ta.crossover(ma3, ma5) and
    ma5 > ma10 and
    close > ma20 and
    close > ma120 and
    volume > vol_ma * 1.2

cond_head_start =
    timeframe.isintraday and
    gap_pct >= head_start_gap_pct and
    is_bull and
    volume > vol_ma * 1.5 and
    close > ma20

//==============================================================================
// 4. 狀態管理與買點執行
//==============================================================================
var float last_buy_price = na
var float last_sell_price = na
var float last_target_price = na
var float last_stop_price = na
var float last_anchor_price = na
var float high_since_entry = na
var string last_buy_reason = "尚未進場"
var string last_sell_reason = "尚無"
var string last_signal = "觀望"
var int last_buy_bar = na

is_holding = not na(last_buy_price)

buy_reason = ""
buy_target = na
buy_anchor = na

if cond_chong_tian_pao
    buy_reason := "沖天砲"
    buy_anchor := left_low
    buy_target := left_low * first_target_mult
else if cond_second_spring
    buy_reason := "第二春"
    buy_anchor := recent_high_60
    buy_target := close * second_spring_mult
else if cond_small_shrimp
    buy_reason := "小蝦米"
    buy_anchor := math.min(low, low[1])
    buy_target := close * shrimp_target_mult
else if cond_black_swan
    buy_reason := "黑天鵝"
    buy_anchor := low[1]
    buy_target := close * black_swan_mult
else if cond_wukong
    buy_reason := "悟空翻身"
    buy_anchor := bundle_low
    buy_target := close * wukong_target_mult
else if cond_head_start
    buy_reason := "搶頭香"
    buy_anchor := open
    buy_target := close * head_start_mult

trigger_buy = buy_reason != "" and not is_holding

if is_holding
    high_since_entry := na(high_since_entry) ? high : math.max(high_since_entry, high)
else
    high_since_entry := na

//==============================================================================
// 5. 賣點紀律
//==============================================================================
float pnl_pct = is_holding ? (close - last_buy_price) / last_buy_price * 100 : na

cond_stop_loss =
    is_holding and
    close <= last_buy_price * (1 - stop_loss_pct / 100)

cond_break_ma10 =
    is_holding and
    close < ma10 * (1 - trail_break_pct / 100) and
    volume > vol_ma * sell_vol_mult

cond_target_hit =
    is_holding and
    not na(last_target_price) and
    close >= last_target_price

cond_blowoff =
    is_holding and
    is_big_bear and
    volume > vol_ma * sell_vol_mult and
    close < open and
    high_since_entry > last_buy_price

sell_reason = ""
sell_price = na

if cond_stop_loss
    sell_reason := "固定停損"
    sell_price := close
else if cond_break_ma10
    sell_reason := "跌破10日爆量"
    sell_price := close
else if cond_target_hit
    sell_reason := "達目標價"
    sell_price := last_target_price
else if cond_blowoff
    sell_reason := "高檔爆量黑K"
    sell_price := close

trigger_sell = sell_reason != "" and is_holding

//==============================================================================
// 6. 標籤與提醒
//==============================================================================
if trigger_buy
    last_buy_price := close
    last_target_price := buy_target
    last_stop_price := close * (1 - stop_loss_pct / 100)
    last_anchor_price := buy_anchor
    high_since_entry := high
    last_buy_reason := buy_reason
    last_signal := "買進 " + buy_reason
    last_buy_bar := bar_index

    buy_price_str = str.tostring(last_buy_price, "#.##")
    target_str = na(last_target_price) ? "-" : str.tostring(last_target_price, "#.##")
    buy_txt = "✅ 買點\n" + buy_reason + "\n價: " + buy_price_str + "\n目標: " + target_str

    label.new(
         bar_index,
         low,
         buy_txt,
         color=color.yellow,
         textcolor=color.black,
         style=label.style_label_up,
         size=size.small,
         yloc=yloc.belowbar)

    alert("買進提醒：" + buy_reason + "，價位 " + buy_price_str + "，目標 " + target_str, alert.freq_once_per_bar)

if trigger_sell
    sell_pnl = (sell_price - last_buy_price) / last_buy_price * 100
    sell_price_str = str.tostring(sell_price, "#.##")
    sell_pnl_str = str.tostring(sell_pnl, "#.##") + "%"
    sell_txt = "🚩 賣點\n" + sell_reason + "\n價: " + sell_price_str + "\n報酬: " + sell_pnl_str

    label.new(
         bar_index,
         high,
         sell_txt,
         color=sell_pnl >= 0 ? color.orange : color.red,
         textcolor=color.white,
         style=label.style_label_down,
         size=size.small,
         yloc=yloc.abovebar)

    alert("賣出提醒：" + sell_reason + "，價位 " + sell_price_str + "，報酬 " + sell_pnl_str, alert.freq_once_per_bar)

    last_sell_price := sell_price
    last_sell_reason := sell_reason
    last_signal := "賣出 " + sell_reason
    last_buy_price := na
    last_target_price := na
    last_stop_price := na
    last_anchor_price := na
    high_since_entry := na
    last_buy_bar := na

//==============================================================================
// 7. 視覺呈現
//==============================================================================
plot(ma10, "10日", color=color.new(color.orange, 0), linewidth=1)
plot(ma20, "20日", color=color.new(color.blue, 0), linewidth=1)
plot(ma60, "60日", color=color.new(color.purple, 0), linewidth=1)
plot(ma120, "120日", color=color.new(color.red, 0), linewidth=2)

active_pattern =
    cond_chong_tian_pao ? "沖天砲" :
    cond_second_spring ? "第二春" :
    cond_small_shrimp ? "小蝦米" :
    cond_black_swan ? "黑天鵝" :
    cond_wukong ? "悟空翻身" :
    cond_head_start ? "搶頭香" :
    "觀望"

bgcolor(
     show_signal_bg ?
     (cond_chong_tian_pao ? color.new(color.lime, 88) :
      cond_second_spring ? color.new(color.teal, 88) :
      cond_small_shrimp ? color.new(color.aqua, 88) :
      cond_black_swan ? color.new(color.orange, 88) :
      cond_wukong ? color.new(color.fuchsia, 88) :
      cond_head_start ? color.new(color.yellow, 88) : na) : na)

holding_text = is_holding ? "持倉中" : "未持倉"
holding_color = is_holding ? color.lime : color.gray

live_pnl = is_holding ? (close - last_buy_price) / last_buy_price * 100 : na
live_pnl_str = is_holding ? str.tostring(live_pnl, "#.##") + "%" : "-"
target_str_now = is_holding and not na(last_target_price) ? str.tostring(last_target_price, "#.##") : "-"
stop_str_now = is_holding and not na(last_stop_price) ? str.tostring(last_stop_price, "#.##") : "-"
buy_price_str_now = is_holding ? str.tostring(last_buy_price, "#.##") : "-"
sell_price_str_now = not na(last_sell_price) ? str.tostring(last_sell_price, "#.##") : "-"
anchor_str = is_holding and not na(last_anchor_price) ? str.tostring(last_anchor_price, "#.##") : "-"

trend_text =
    close > ma120 and ma20 > ma60 ? "多頭" :
    close < ma120 and ma20 < ma60 ? "空頭" :
    "整理"

trend_color =
    trend_text == "多頭" ? color.lime :
    trend_text == "空頭" ? color.red :
    color.yellow

var table info_table = table.new(position.top_right, 2, 10, border_width=1, frame_color=color.gray)
if barstate.islast
    table.cell(info_table, 0, 0, "當前形態", bgcolor=color.black, text_color=color.white)
    table.cell(info_table, 1, 0, active_pattern, text_color=color.yellow)

    table.cell(info_table, 0, 1, "持倉狀態", text_color=color.silver)
    table.cell(info_table, 1, 1, holding_text, text_color=holding_color)

    table.cell(info_table, 0, 2, "買進價", text_color=color.silver)
    table.cell(info_table, 1, 2, buy_price_str_now, text_color=color.yellow)

    table.cell(info_table, 0, 3, "停損價", text_color=color.silver)
    table.cell(info_table, 1, 3, stop_str_now, text_color=color.red)

    table.cell(info_table, 0, 4, "目標價", text_color=color.silver)
    table.cell(info_table, 1, 4, target_str_now, text_color=color.lime)

    table.cell(info_table, 0, 5, "即時報酬", text_color=color.silver)
    table.cell(info_table, 1, 5, live_pnl_str, text_color=is_holding ? (live_pnl >= 0 ? color.lime : color.red) : color.gray)

    table.cell(info_table, 0, 6, "進場依據", text_color=color.silver)
    table.cell(info_table, 1, 6, is_holding ? last_buy_reason : "-", text_color=color.white)

    table.cell(info_table, 0, 7, "基準錨點", text_color=color.silver)
    table.cell(info_table, 1, 7, anchor_str, text_color=color.aqua)

    table.cell(info_table, 0, 8, "趨勢 / 上次賣", text_color=color.silver)
    table.cell(info_table, 1, 8, trend_text + " / " + sell_price_str_now, text_color=trend_color)

    table.cell(info_table, 0, 9, "最後訊號", text_color=color.silver)
    table.cell(info_table, 1, 9, last_signal, text_color=color.white)
